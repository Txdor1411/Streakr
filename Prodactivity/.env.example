# Supabase credentials. Copy this file to `.env.local` and fill in the values
# from your project's API settings (https://supabase.com/dashboard → Settings →
# API). The anon key is safe to ship in a client app; it only grants what your
# row-level security policies allow.
#
# Without these, the app runs fully local-first (on-device storage, no account).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
